{
  "name": "portfolio-template",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Mister-Hope"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mister-Hope/portfolio-template.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "unrun": "^0.2.34",
    "vite": "^8.0.8"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
