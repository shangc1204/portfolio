{
  "name": "portfolio-template",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Mister-Hope"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mister-Hope/portfolio-template.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "nano-staged": "0.9.0",
    "npm-check-updates": "^19.6.3",
    "oxc-config-hope": "0.0.8",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.17.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "unrun": "^0.2.32",
    "vite": "^8.0.0"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "packageManager": "pnpm@10.32.1"
}
