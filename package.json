{
  "name": "cheng-shang-portfolio",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Cheng Shang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shangc1204/portfolio.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@mdit/plugin-attrs": "^0.25.1",
    "@mdit/plugin-mark": "^0.23.1",
    "@mr-hope/tsconfig": "0.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.2.0",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "unrun": "^0.3.0",
    "vite": "^8.0.14"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.3.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^22.18.0 || ^24.0.0 || ^26.0.0",
      "onFail": "error"
    }
  }
}
